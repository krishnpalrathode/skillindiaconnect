{
  "name": "@skillindiaconnect/shared-types",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "generate": "openapi-typescript ../contract/openapi.yaml -o src/generated/api.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" --ignore-pattern \"src/generated/**\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.4.0"
  }
}
