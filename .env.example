# Runtime environment
NODE_ENV=development
PORT=3001

# PostgreSQL -- matches docker-compose defaults
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/skillindiaconnect_dev

# Redis -- matches docker-compose defaults
REDIS_URL=redis://localhost:6379

# Web app -- origin of the NestJS API server (scheme + host + port, NO trailing slash, NO /api/v1 path).
# The /api/v1 prefix is appended by apps/web/src/lib/api/client.ts at build time.
NEXT_PUBLIC_API_URL=http://localhost:3001

# JWT secrets (min 32 chars each -- generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string-at-least-32-chars-long
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string-at-least-32-ch

# JWT TTLs (optional -- defaults shown)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Google OAuth (candidates only)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# Frontend base URL -- used for OAuth redirect and CORS origin
WEB_APP_URL=http://localhost:3000

# Cloudflare R2 -- S3-compatible object storage for documents, photos, and resumes
# Local dev: point at an R2 dev bucket or a local S3-compatible mock (e.g. MinIO)
# The presign/HEAD logic is identical regardless of which endpoint is used.
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=skillindiaconnect-dev
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
